# .env - Variables para desarrollo local

# =====================
# DATABASE CONFIGURATION
# =====================
POSTGRES_PORT=5432
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pedidos_poseidon
DB_USERNAME=poseidon
DB_PASSWORD=poseidonadmin2025

# =====================
# APPLICATION CONFIGURATION
# =====================
APP_PORT=8080
SERVER_PORT=8080

# =====================
# HIBERNATE/JPA CONFIGURATION
# =====================
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=true

# =====================
# LOGGING CONFIGURATION
# =====================
LOG_LEVEL=INFO

# =====================
# SECURITY CONFIGURATION
# =====================
JWT_SECRET=myVeryLongAndSecureJwtSecretKey12345678901234567890
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# =====================
# DEVELOPMENT FLAGS
# =====================
# Cambiar a true solo en desarrollo local
DEBUG_MODE=false
ENABLE_SQL_LOGGING=false

# =====================
# SCHEDULING CONFIGURATION
# =====================
SCHEDULER_POOL_SIZE=5
TASK_EXECUTION_POOL_SIZE=10